---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	src: ImageMetadata;
	alt: string;
	caption?: string;
	width?: number;
	sizes?: string;
	loading?: 'eager' | 'lazy';
	decoding?: 'sync' | 'async' | 'auto';
}

const {
	src,
	alt,
	caption,
	width,
	sizes = '(min-width: 720px) 720px, 100vw',
	loading = 'lazy',
	decoding = 'async',
} = Astro.props;
---

<figure class="captioned-image">
	<Image
		src={src}
		alt={alt}
		width={width}
		sizes={sizes}
		loading={loading}
		decoding={decoding}
	/>
	{caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
	.captioned-image {
		margin: 2rem 0;
	}

	.captioned-image :global(img) {
		display: block;
		margin: 0 auto;
	}

	figcaption {
		margin-top: 0.75rem;
		color: rgb(var(--gray));
		font-size: 0.95rem;
		text-align: center;
	}
</style>